<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Roadside Assistance</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <a href="/" class="logo">🔧 RoadAssist</a>
        <div>
            <a href="/login">Login</a>
            <a href="/register">Register</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="hero">
        <h1>🚗 Stuck on the Road?</h1>
        <p>Get instant help from nearby mechanics anytime, anywhere!</p>
        <a href="/register" class="btn btn-secondary">Get Started</a>
        <a href="/login" class="btn btn-secondary">Login</a>
    </div>

    <!-- Features Section -->
    <div class="features">
        <div class="feature-card">
            <div class="icon">🔍</div>
            <h3>Find Mechanics</h3>
            <p>Search for available mechanics near your location instantly</p>
        </div>
        <div class="feature-card">
            <div class="icon">📋</div>
            <h3>Book Instantly</h3>
            <p>Book a mechanic in seconds for any vehicle issue</p>
        </div>
        <div class="feature-card">
            <div class="icon">📍</div>
            <h3>Track Status</h3>
            <p>Track your booking status in real time</p>
        </div>
        <div class="feature-card">
            <div class="icon">⭐</div>
            <h3>Rate & Review</h3>
            <p>Rate mechanics after service for better quality</p>
        </div>
        <div class="feature-card">
            <div class="icon">🛡️</div>
            <h3>Verified Mechanics</h3>
            <p>All mechanics are verified and approved by admin</p>
        </div>
        <div class="feature-card">
            <div class="icon">💰</div>
            <h3>Transparent Pricing</h3>
            <p>Know the cost before you pay — no hidden charges</p>
        </div>
    </div>

    <!-- Services Section -->
    <div style="padding: 30px; background: white;">
        <h2 style="text-align:center; color:#e74c3c; margin-bottom:30px;">
            Our Services
        </h2>
        <div class="features">
            <div class="feature-card">
                <div class="icon">🔧</div>
                <h3>Engine Issue</h3>
                <p>Expert mechanics for all engine problems</p>
            </div>
            <div class="feature-card">
                <div class="icon">🛞</div>
                <h3>Tyre Puncture</h3>
                <p>Quick tyre replacement and repair</p>
            </div>
            <div class="feature-card">
                <div class="icon">🔋</div>
                <h3>Battery Jump</h3>
                <p>Dead battery? We got you covered</p>
            </div>
            <div class="feature-card">
                <div class="icon">🚛</div>
                <h3>Towing</h3>
                <p>Safe towing to nearest garage</p>
            </div>
            <div class="feature-card">
                <div class="icon">⛽</div>
                <h3>Fuel Delivery</h3>
                <p>Emergency fuel delivered to you</p>
            </div>
            <div class="feature-card">
                <div class="icon">🛠️</div>
                <h3>Other Issues</h3>
                <p>Any other vehicle problem solved</p>
            </div>
        </div>
    </div>

    <!-- How it works -->
    <div style="padding: 50px 30px; text-align:center;">
        <h2 style="color:#e74c3c; margin-bottom:40px;">How It Works</h2>
        <div class="features">
            <div class="feature-card">
                <div class="icon">1️⃣</div>
                <h3>Register</h3>
                <p>Create your account as a vehicle owner</p>
            </div>
            <div class="feature-card">
                <div class="icon">2️⃣</div>
                <h3>Find Mechanic</h3>
                <p>Search available mechanics near you</p>
            </div>
            <div class="feature-card">
                <div class="icon">3️⃣</div>
                <h3>Book Service</h3>
                <p>Select service type and book instantly</p>
            </div>
            <div class="feature-card">
                <div class="icon">4️⃣</div>
                <h3>Get Help</h3>
                <p>Mechanic arrives and fixes your vehicle</p>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer>
        <p>© 2024 RoadAssist — All Rights Reserved</p>
        <p style="margin-top:8px; color:#aaa;">
            Made with ❤️ for emergency vehicle assistance
        </p>
    </footer>

</body>
</html>